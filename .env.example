INSEE_API_KEY=your_insee_api_key_here

# Départements à interroger (code INSEE, séparés par des virgules)
DEPARTMENTS=76,27

# Codes NAF à filtrer (format NAF Rev. 2 avec point, séparés par des virgules)
# Liste curée "professions libérales" : juridique, comptable, conseil,
# architectes/ingénieurs, design/traduction, santé, formation.
NAF_CODES=69.10Z,69.20Z,70.21Z,70.22Z,71.11Z,71.12A,71.12B,71.20B,74.10Z,74.20Z,74.30Z,74.90A,74.90B,75.00Z,85.59A,85.59B,86.21Z,86.22A,86.22B,86.22C,86.23Z,86.90D,86.90E,86.90F
